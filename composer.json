{
    "name": "webisters/image",
    "description": "Webisters Image Library",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "image",
        "opacity",
        "watermark",
        "filter",
        "flatten",
        "gd"
    ],
    "authors": [
        {
            "name": "Hafiz Muhammad Moaz",
            "email": "hafizmoazkhalid@gmail.com",
            "homepage": "https://github.com/HafizMMoaz"
        }
    ],
    "homepage": "https://webisters.com/packages/image",
    "support": {
        "email": "support@webisters.com",
        "issues": "https://github.com/webisters/image/issues",
        "forum": "https://github.com/webisters/forum",
        "source": "https://github.com/webisters/image",
        "docs": "https://webisters.com"
    },
    "funding": [
        {
            "type": "Webisters Sponsor",
            "url": "https://webisters.com/sponsor"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-gd": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "webisters/coding-standard": "*",
        "jetbrains/phpstorm-attributes": "^1.0",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Framework\\Image\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Image\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}


